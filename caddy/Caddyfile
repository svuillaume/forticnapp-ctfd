{
    # Use Caddy's built-in local CA for all certs (no Let's Encrypt)
    local_certs

    # Caddy admin API — internal health checks only
    admin 0.0.0.0:2019
}

# ── CTFd ──────────────────────────────────────────────────────────────────────
# FQDN defaults to "localhost" (see docker-compose).
# Caddy auto-issues a self-signed cert for whatever hostname is set.
{env.FQDN} {

    tls internal

    encode gzip

    header {
        X-Content-Type-Options    nosniff
        X-Frame-Options           SAMEORIGIN
        Referrer-Policy           strict-origin-when-cross-origin
        -Server
    }

    respond /caddy-health 200

    reverse_proxy ctfd:8000 {
        header_up Host        {upstream_hostport}
        header_up X-Real-IP   {remote_host}
        header_up Connection  {http.request.header.Connection}
        header_up Upgrade     {http.request.header.Upgrade}
    }
}

# ── Trigger service — port 5555 ───────────────────────────────────────────────
{env.FQDN}:5555 {

    tls internal

    header {
        Access-Control-Allow-Origin  "https://{env.FQDN}"
        Access-Control-Allow-Methods "GET, POST, OPTIONS"
        Access-Control-Allow-Headers "Content-Type"
        -Server
    }

    @options method OPTIONS
    respond @options 204

    reverse_proxy trigger:5555
}
