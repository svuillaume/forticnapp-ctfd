# ----------------------------------------------------------------------
# FortiCNAPP CTF - environment template
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ----------------------------------------------------------------------

# --- CTFd ---
CTFD_HOST_PORT=8000
MYSQL_ROOT_PASSWORD=replace-me-strong-root-pw
MYSQL_PASSWORD=replace-me-strong-ctfd-pw

# Generated AFTER first CTFd boot:
#   Admin Panel -> Settings -> Tokens -> Generate
CTFD_ADMIN_TOKEN=ctfd_REPLACE_AFTER_FIRST_BOOT

# --- FortiCNAPP API credentials ---
# Console: Settings -> API Keys -> Create New
# The downloaded JSON contains keyId + secret + account.
FORTICNAPP_ACCOUNT=acme-prod          # e.g. acme-prod.lacework.net -> 'acme-prod'
FORTICNAPP_SUBACCOUNT=                # leave empty if not using sub-accounts
FORTICNAPP_API_KEY_ID=ACME_1234567890ABCDEF
FORTICNAPP_API_SECRET=_replace_with_secret_

# --- Generator behaviour ---
# MOCK_MODE=true  -> use ./sample_data/*.json instead of the real API
#                    (perfect for offline rehearsals & travelling SEs)
MOCK_MODE=false

# SANITIZE=true   -> strip customer-identifiable data (account IDs, ARNs,
#                    hostnames, emails) before turning findings into
#                    challenges. ALWAYS leave true for customer demos.
SANITIZE=true

# How far back to pull alerts (hours)
LOOKBACK_HOURS=72

# Cap challenges per category so the CTF stays curated, not a firehose
MAX_CHALLENGES_PER_CATEGORY=5

# --- Static CTF (bridge-static) ---
# No FortiCNAPP API access needed — uses pre-authored YAML challenge schema.
# Run with:  docker compose run --rm bridge-static
#
# CTF event display name (used in CTFd header and challenge descriptions)
CTF_NAME=FortiCNAPP Cloud Defender Challenge
