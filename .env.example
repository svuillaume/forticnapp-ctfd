# ----------------------------------------------------------------------
# FortiCNAPP CTF — environment template
# Copy to .env and fill in your values.  NEVER commit .env.
# Run:  python ctl.py  — the wizard fills everything in interactively.
# ----------------------------------------------------------------------

# ── CTFd Flask session key — auto-generated by ctl.py ─────────────────
SECRET_KEY=change_me_secret_key

# ── Database passwords (internal only, never exposed) ─────────────────
MYSQL_ROOT_PASSWORD=root
MYSQL_PASSWORD=root

# ── CTFd admin account ─────────────────────────────────────────────────
# Used by ctl.py to complete the first-run wizard automatically.
CTFD_ADMIN_NAME=admin
CTFD_ADMIN_EMAIL=admin@ctf.local
CTFD_ADMIN_PASSWORD=admin

# ── Auto-filled by ctl.py on first start — do not edit manually ───────
CTFD_ADMIN_TOKEN=

# ── Hostname (optional) ────────────────────────────────────────────────
# Leave blank to use localhost. Set to your IP or hostname if participants
# connect from other machines. Caddy issues a self-signed cert for it.
FQDN=

# ── FortiCNAPP API credentials (Live CTF mode only) ───────────────────
# Required for dynamic challenge generation from your tenant.
# FortiCNAPP Console → Settings → API Keys → Create New → download JSON.
# Leave blank for CTF Lab (static) mode.
FORTICNAPP_ACCOUNT=
FORTICNAPP_SUBACCOUNT=
FORTICNAPP_API_KEY_ID=
FORTICNAPP_API_SECRET=

# ── Challenge generator behaviour ─────────────────────────────────────
MOCK_MODE=false
SANITIZE=true
LOOKBACK_HOURS=72
MAX_CHALLENGES_PER_CATEGORY=5
