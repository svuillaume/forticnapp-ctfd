# ----------------------------------------------------------------------
# FortiCNAPP CTF — environment template
# Copy to .env and fill in your values.  NEVER commit .env.
#
# SETUP ORDER:
#   Step 1 — Fill in SECRET_KEY, then run:  python ctl.py  → option 1 (First boot)
#   Step 2 — Complete the CTFd setup wizard at http://localhost:8000
#   Step 3 — Admin Panel → Settings → Tokens → Generate → paste below
#   Step 4 — python ctl.py → option 2 (Start with trigger)
# ----------------------------------------------------------------------

# ── Step 1 — Required before first start ──────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_secret_key

# Database passwords (internal only — containers talk to each other, never exposed)
MYSQL_ROOT_PASSWORD=root
MYSQL_PASSWORD=root

# ── Step 3 — Fill in after CTFd setup wizard ──────────────────────────
# Admin Panel → Settings → Tokens → Generate
CTFD_ADMIN_TOKEN=

# ── Optional: HTTPS via Caddy + DuckDNS ───────────────────────────────
# FQDN    — your DuckDNS subdomain (e.g. samvblogs.duckdns.org)
# HTTPS_PORT — TCP port for CTFd HTTPS (default 4443; use 443 for standard)
# DUCKDNS_TOKEN — from https://www.duckdns.org (logged-in account page)
FQDN=
HTTPS_PORT=4443
DUCKDNS_TOKEN=

# ── Optional: Challenge generator behaviour ───────────────────────────
# FortiCNAPP API credentials are entered via the web UI —
# no need to store them here.
MOCK_MODE=false
SANITIZE=true
LOOKBACK_HOURS=72
MAX_CHALLENGES_PER_CATEGORY=5
