# ----------------------------------------------------------------------
# FortiCNAPP CTF — environment template
# Copy to .env and fill in your values.  NEVER commit .env.
# ----------------------------------------------------------------------

# ── CTFd ──────────────────────────────────────────────────────────────
# Flask secret key — generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_secret_key

# Database passwords — change before production use
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_PASSWORD=change_me_ctfd

# CTFd admin API token — generate AFTER the first-boot wizard:
#   Admin Panel → Settings → Tokens → Generate
CTFD_ADMIN_TOKEN=

# ── HTTPS / Caddy reverse proxy (optional) ────────────────────────────
# Required only when running Caddy for HTTPS.
# Get your token from https://www.duckdns.org (logged-in account page).
# Make sure the A record for your DuckDNS domain points to this host.
DUCKDNS_TOKEN=

# ── Challenge generator behaviour ─────────────────────────────────────
# FortiCNAPP API credentials are entered via the web UI when clicking
# "Load Live Challenges" — no need to store them here.
MOCK_MODE=false
SANITIZE=true
LOOKBACK_HOURS=72
MAX_CHALLENGES_PER_CATEGORY=5
