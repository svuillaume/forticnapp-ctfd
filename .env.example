# ----------------------------------------------------------------------
# FortiCNAPP CTF — environment template
# Copy to .env and fill in your values.  NEVER commit .env.
# ----------------------------------------------------------------------

# ── HTTPS / Caddy reverse proxy ───────────────────────────────────────
# DuckDNS token for Let's Encrypt DNS-01 certificate issuance.
# Get it from https://www.duckdns.org (your logged-in account page).
# Make sure the A record for your DuckDNS domain points to this host.
DUCKDNS_TOKEN=

# ── CTFd ──────────────────────────────────────────────────────────────
# With Caddy running, CTFd and trigger are bound to 127.0.0.1 only.
# Set CTFD_HOST_PORT=0 to disable direct host access completely.
CTFD_HOST_PORT=8000

# Database passwords — change before production use
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_PASSWORD=change_me_ctfd

# Flask secret key — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_secret_key

# CTFd admin API token — generate AFTER first boot:
#   Admin Panel → Settings → Tokens → Generate
CTFD_ADMIN_TOKEN=

# ── FortiCNAPP Live API (only needed for Dynamic Mode) ────────────────
# Obtain from FortiCNAPP: Settings → API Keys → Create
FORTICNAPP_ACCOUNT=
FORTICNAPP_SUBACCOUNT=
FORTICNAPP_API_KEY_ID=
FORTICNAPP_API_SECRET=

# ── Challenge generator behaviour ─────────────────────────────────────
MOCK_MODE=false
SANITIZE=true
LOOKBACK_HOURS=72
MAX_CHALLENGES_PER_CATEGORY=5
